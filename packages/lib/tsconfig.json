{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "name": "@pexjet/lib",
  "main": "./src/index.ts",
  "types": "./src/**/*.ts",
  "exports": {
    ".": "./src/**/*.ts",
    "./external-auth": "./src/external-auth.ts"
  }
}
